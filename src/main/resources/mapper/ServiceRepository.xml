<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="py.com.solar.commonsapi.repository.ServiceRepository">

    <select id="callById" statementType="CALLABLE">
        begin
        pre_ini_aplicacion;
        pre_ini_programa(#{serviceName},1,2);
        end;
    </select>

    <select id="setSystemUser" statementType="CALLABLE">
        begin
            RAK_SISTEMA.G_USUARIO := #{username};
        end;
    </select>

    <select id="initServiceUserSession" statementType="CALLABLE">
        begin
            pre_ini_aplicacion;
            pre_ini_programa('user-api-service',1,2);
            rak_sistema.g_usuario := UPPER(#{username});
        end;
    </select>
    
    <select id="getConfidentClient" resultType="string">
        SELECT PERSONAS.FUG_CLIENTE_CONFIDENCIAL(#{personId},#{username}) FROM DUAL
    </select>

    <select id="getSpecialClient" resultType="string">
        SELECT PERSONAS.FUG_CLIENTE_EMPLEADO(#{username},#{personId}) FROM DUAL
    </select>

    <select id="getPersonExists" resultType="int">
        SELECT COUNT(*) FROM IT.BA_PERSONAS bp WHERE COD_PERSONA = #{personId}
    </select>
</mapper>